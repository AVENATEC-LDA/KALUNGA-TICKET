APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:replace-with-generated-secret
JWT_SECRET=replace-with-generated-secret
APP_URL=https://api.seu-dominio.com
APP_FRONTEND_URL=https://seu-dominio.com
APP_CDN_URL=https://seu-cdn-ou-bucket-publico
APP_DISABLE_REGISTRATION=false
APP_SAAS_MODE_ENABLED=false
APP_SAAS_STRIPE_APPLICATION_FEE_PERCENT=0
APP_SAAS_STRIPE_APPLICATION_FEE_FIXED=0
LOG_CHANNEL=stderr
LOG_LEVEL=info
QUEUE_CONNECTION=redis
DB_CONNECTION=pgsql
DB_HOST=seu-host-postgres
DB_PORT=5432
DB_DATABASE=seu-banco
DB_USERNAME=seu-usuario
DB_PASSWORD=sua-senha
